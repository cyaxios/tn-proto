# Wheel + editable-install artifacts
build/
dist/
wheel-test/
wheel-test-venv/
*.egg-info/
__pycache__/
*.pyc

# Do not commit ceremony key material. Keys/ is always generated by
# tn.init and always contains secrets.
keys/

# Scratch yaml from smoke tests and vault pokes.
test_*.yaml
logs/

# vcpkg local cache (manifest keeps vcpkg.json checked in)
vcpkg_installed/

bench/results/*/
!bench/results/.gitkeep
!bench/results/baselines/
